# ─── Backend (FastAPI on Render) ───────────────────
# Leave empty to use SQLite locally (no Supabase needed)
SUPABASE_URL=
SUPABASE_KEY=

# Render sets PORT automatically; locally defaults to 8000
# PORT=8000

# Set by Render automatically — used for keep-alive self-ping
# RENDER_EXTERNAL_URL=https://ai-stock-market-scanner.onrender.com

# Auto-start the background scheduler on boot (default: true)
AUTO_START_SCHEDULER=true

# Memory tuning for Render free tier (512 MB)
FULL_SCAN_CHUNK_SIZE=5
FULL_SCAN_FETCH_WORKERS=1
FULL_SCAN_ANALYSIS_WORKERS=1
FULL_SCAN_TRAIN_SAMPLE=10

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,https://stockprediction-pi.vercel.app

# ─── Frontend (Next.js on Vercel) ──────────────────
# For local dev, point at FastAPI directly:
NEXT_PUBLIC_API_URL=http://localhost:8000
# For Vercel production, leave blank (uses /api/* rewrites)
# NEXT_PUBLIC_API_URL=

# Vercel env (set in Vercel dashboard → Settings → Environment Variables):
# BACKEND_URL=https://ai-stock-market-scanner.onrender.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
