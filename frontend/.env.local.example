# For local development — point at your FastAPI server
NEXT_PUBLIC_API_URL=http://localhost:8000

# For Vercel production, do NOT set NEXT_PUBLIC_API_URL.
# Instead set BACKEND_URL in Vercel dashboard:
# BACKEND_URL=https://ai-stock-market-scanner.onrender.com

# Optional: Supabase for client-side auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
